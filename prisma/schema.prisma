generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String     @id @default(cuid())
  email       String?    @unique
  username    String     @unique
  firstName   String
  lastName    String
  password    String
  role        Role       @default(MEMBER)
  ownedLeads   Lead[]     @relation("OwnedLeads")
  lockedLeads  Lead[]     @relation("LockedLeads")
  createdLeads Lead[]     @relation("CreatedLeads")
  activities   Activity[]
  createdTrackedLinks TrackedLink[] @relation("CreatedTrackedLinks")
}

model Invite {
  id        String    @id @default(cuid())
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime
}

model Lead {
  id          String  @id @default(cuid())
  number      Int     @unique @default(autoincrement())
  companyName String?
  phone       String?
  website     String?
  email       String?
  note        String?

  status  LeadStatus @default(NEW)
  origin  LeadOrigin @default(MARKETING_CALL) // ako sa lead dostal do systému (marketing hovor / priamo / odporúčanie)
  owner   User?      @relation("OwnedLeads", fields: [ownerId], references: [id])
  ownerId String? // kto to má aktuálne na starosti (N → M)

  // KEDY ĎALEJ – srdce appky
  nextActionKind NextActionKind?
  nextActionAt   DateTime?
  nextActionNote String? // "overiť či prišiel mail s návrhom"

  callbackKind CallbackKind? // prečo je v CALLING fronte
  callbackAt   DateTime? // krátkodobý návrat v /calls (CALLING)
  callbackNote String? // "vraj sa ozvať o hodinu, bola na porade"

  // KEDY SME ČO POSLALI – presne to, čo si chcel vidieť na prvý pohľad
  quoteSentAt   DateTime? // cenová ponuka
  designSentAt  DateTime? // dizajnový návrh
  designUrl     String?
  aboutUsSentAt DateTime? // info o nás / odpoveď na ich mail

  price     Decimal? @db.Decimal(10, 2) // celková nastrelená cena – tá sa zobrazuje
  priceNote String? // rozpis/poznámka: "499 stránka + 299 admin systém" – na hover

  lostReason String? // "nemajú záujem", "zlé číslo"

  // kto kontakt pridal – pre štatistiky pridávania
  creator     User?   @relation("CreatedLeads", fields: [createdById], references: [id])
  createdById String?

  // soft delete
  deletedAt DateTime?

  // claim (future-proof, zatiaľ nevyužité)
  lockedBy   User?     @relation("LockedLeads", fields: [lockedById], references: [id])
  lockedById String?
  lockedAt   DateTime?

  activities   Activity[]
  trackedLinks TrackedLink[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([status, callbackKind])
  @@index([deletedAt])
  @@index([createdById, createdAt])
}

enum LeadStatus {
  NEW // pridané, ešte sa nevolalo
  CALLING // ← nový: marketing volá, ešte sa nedovolal
  ACTIVE // rieši sa – všetko medzi prvým hovorom a koncom
  SNOOZED // "ozvite sa o 4 mesiace" – spí, zobudí sa samo
  WON // klient ide do projektu
  LOST // koniec (nezáujem, zlý kontakt, terminované)
  UNREACHABLE // ← nový: zlé číslo / nedá sa spojiť
}

model Activity {
  id        String           @id @default(cuid())
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  type      ActivityType
  category  ActivityCategory
  source    ActivitySource
  outcome   CallOutcome?
  note      String?
  meta      Json? // štruktúrované detaily: napr. diff zmien { changes: [{ field, from, to }] } alebo verzia trackeru
  createdAt DateTime         @default(now())

  @@index([leadId])
  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([source, type, createdAt])
}

enum ActivityType {
  CALL
  QUOTE_SENT
  DESIGN_SENT
  EMAIL_SENT // info o nás, odpoveď, čokoľvek
  SMS_SENT
  NOTE
  NEXT_ACTION_SET
  NEXT_ACTION_CHANGED
  NEXT_ACTION_CLEARED
  CONTACT_UPDATED
  STATUS_CHANGED
  OWNER_CHANGED
  OUTCOME_CORRECTED
  TRACKER_ATTACHED // pripojený tracked link (dizajn/CP)
  TRACKER_UPDATED // nová verzia – „dizajn aktualizovaný"
  TRACKER_OPENED // klient otvoril (míľnik, hlavne po update)
}

enum CallOutcome {
  NO_ANSWER // 2b nezdvihli
  BAD_NUMBER // 2a zlé číslo
  NOT_INTERESTED // 2c nie
  CALL_AGAIN // 2d "zavolajte mi vtedy a vtedy"
  WANTS_QUOTE // 2e chce CP
  WANTS_DESIGN // 2f chce návrh
  WANTS_EMAIL // 2g máme napísať
  SNOOZE // 2h "o X mesiacov"
  POSITIVE // videli, páči sa, posúva sa to
}

enum Role {
  MEMBER // D – marketing: vidí len svoju prácu
  MANAGER // N – vidí všetko, vie pridávať leady, meniť vlastníka
  ADMIN // ty – všetko + pozvánky, používatelia, mazanie
}

enum CallbackKind {
  RETRY // nedovolala sa – skúsiť znova, bez presného času
  SCHEDULED // dohodnutý čas – „pani povedala 15:00"
}

enum ActivityCategory {
  BUSINESS
  PLANNING
  AUDIT
}

enum ActivitySource {
  CALL_QUEUE
  PIPELINE
  CONTACTS
  ADMIN
}

enum NextActionKind {
  CALL
  SEND_QUOTE
  SEND_DESIGN
  SEND_EMAIL
  WAITING_FOR_CLIENT
  CUSTOM
}

enum LeadOrigin {
  MARKETING_CALL // klasický flow: marketing volá
  DIRECT // priamy kontakt (stretnutie, sám napísal)
  REFERRAL // odporúčanie
  OTHER
}

// ── TRACKING ─────────────────────────────────────────────────────────────────
// TrackedLink = jeden token / jedna proposal linka. Lead môže mať viac (varianty).
// TrackedLinkVersion = log aktualizácií (v1, v2…), každá môže mať vlastnú URL + poznámku.
// TrackedEvent = jednotlivé otvorenia/engagement, označkované verziou ktorú videli.

enum TrackedLinkKind {
  DESIGN // dizajnový návrh
  QUOTE // cenová ponuka (tracknutá stránka)
  OTHER // samostatný tracker bez leadu
}

enum TrackedEventType {
  PAGE_VIEW // stránka sa načítala (slabý signál, môže byť skener)
  ENGAGED_VIEW // reálny engagement (čas/scroll) – nesie durationMs
}

model TrackedLink {
  id    String          @id @default(cuid())
  token String          @unique // náhodný, neuhádnuteľný; identifikuje linku server-side
  kind  TrackedLinkKind @default(DESIGN)

  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String? // NULLABLE → samostatný tracker bez klienta

  label              String? // "Variant A" / poznámka pri standalone trackeri
  targetUrl          String? // aktuálna URL (denormalizovaná z poslednej verzie)
  currentVersion     Int       @default(1)
  lastMarkedUpdateAt DateTime? // kedy sa naposledy stlačilo „dizajn aktualizovaný"
  revokedAt          DateTime? // soft-kill linky bez mazania histórie

  createdBy   User?   @relation("CreatedTrackedLinks", fields: [createdById], references: [id])
  createdById String?

  versions  TrackedLinkVersion[]
  events    TrackedEvent[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([leadId])
  @@index([kind])
  @@index([revokedAt])
}

model TrackedLinkVersion {
  id          String   @id @default(cuid())
  link        TrackedLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  linkId      String
  version     Int // 1, 2, 3…
  url         String? // URL platná pre túto verziu (môže sa zmeniť pri update)
  note        String? // „zmenené DNS", „opravené čo chcel klient" alebo nič
  markedAt    DateTime @default(now())
  createdById String? // kto verziu vytvoril (audit; FK pridáme keď budú roly aktívne)

  events TrackedEvent[]

  @@unique([linkId, version])
  @@index([linkId])
}

model TrackedEvent {
  id     String      @id @default(cuid())
  link   TrackedLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  linkId String

  version   TrackedLinkVersion? @relation(fields: [versionId], references: [id])
  versionId String?
  versionAtView Int // ktorú verziu mal klient otvorenú v čase eventu

  type       TrackedEventType
  durationMs Int? // nažhavený čas na stránke (ENGAGED_VIEW)
  ip         String? // surová IP – len pre hrubú geolokáciu cez API (nie presná poloha)
  uaShort    String? // hrubý bucket user-agenta (kvôli bot heuristike)
  botFlag    Boolean          @default(false)
  meta       Json? // future signály: scroll %, CTA id, atď.
  occurredAt DateTime         @default(now())

  @@index([linkId, occurredAt])
  @@index([type, occurredAt])
}
