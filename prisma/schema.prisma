generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  username        String    @unique
  firstName       String
  lastName        String
  password        String
  role            Role      @default(SCOUT)

  // Kontaktné + verifikácia (verifikačný flow sa pridá neskôr)
  phone           String?
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?

  // Životný cyklus účtu
  deletedAt       DateTime? // soft delete — deaktivovaný účet
  lastLoginAt     DateTime? // nastavuje sa pri každom prihlásení
  note            String?   // interná poznámka admina o userovi
  createdAt       DateTime  @default(now())

  ownedLeads   Lead[]     @relation("OwnedLeads")
  lockedLeads  Lead[]     @relation("LockedLeads")
  createdLeads Lead[]     @relation("CreatedLeads")
  activities   Activity[]

  @@index([deletedAt])
  @@index([role])
}

model Invite {
  id          String    @id @default(cuid())
  token       String    @unique
  usedAt      DateTime?
  expiresAt   DateTime
  createdById String?   // kto pozývací link vygeneroval
  forEmail    String?   // pre koho je určený
  forRole     Role      @default(SCOUT) // aká rola sa priradí po registrácii
}

model Lead {
  id          String  @id @default(cuid())
  number      Int     @unique @default(autoincrement())
  companyName String?
  phone       String?
  website     String?
  email       String?
  note        String?

  status      LeadStatus  @default(NEW)
  origin      LeadOrigin  @default(MARKETING_CALL) // ako sa lead dostal do systému (marketing hovor / priamo / odporúčanie)
  projectType ProjectType? // aký typ projektu klient chce (stránka/eshop/katalóg/webapp…)
  owner   User?      @relation("OwnedLeads", fields: [ownerId], references: [id])
  ownerId String? // kto to má aktuálne na starosti (N → M)

  // KEDY ĎALEJ – srdce appky
  nextActionKind NextActionKind?
  nextActionAt   DateTime?
  nextActionNote String? // "overiť či prišiel mail s návrhom"

  callbackKind CallbackKind? // prečo je v CALLING fronte
  callbackAt   DateTime? // krátkodobý návrat v /calls (CALLING)
  callbackNote String? // "vraj sa ozvať o hodinu, bola na porade"

  // KEDY SME ČO POSLALI – presne to, čo si chcel vidieť na prvý pohľad
  quoteSentAt   DateTime? // cenová ponuka
  designSentAt  DateTime? // dizajnový návrh
  designUrl     String?
  aboutUsSentAt DateTime? // info o nás / odpoveď na ich mail

  price     Decimal? @db.Decimal(10, 2) // celková nastrelená cena – tá sa zobrazuje
  priceNote String? // rozpis/poznámka: "499 stránka + 299 admin systém" – na hover

  lostReason String? // "nemajú záujem", "zlé číslo"

  // kto kontakt pridal – pre štatistiky pridávania
  creator     User?   @relation("CreatedLeads", fields: [createdById], references: [id])
  createdById String?

  // soft delete
  deletedAt DateTime?

  // claim (future-proof, zatiaľ nevyužité)
  lockedBy   User?     @relation("LockedLeads", fields: [lockedById], references: [id])
  lockedById String?
  lockedAt   DateTime?

  activities   Activity[]
  designs      Design[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status])
  @@index([status, callbackKind])
  @@index([deletedAt])
  @@index([createdById, createdAt])
}

enum LeadStatus {
  NEW // pridané, ešte sa nevolalo
  CALLING // ← nový: marketing volá, ešte sa nedovolal
  ACTIVE // rieši sa – všetko medzi prvým hovorom a koncom
  SNOOZED // "ozvite sa o 4 mesiace" – spí, zobudí sa samo
  WON // klient ide do projektu
  LOST // koniec (nezáujem, zlý kontakt, terminované)
  UNREACHABLE // ← nový: zlé číslo / nedá sa spojiť
}

model Activity {
  id        String           @id @default(cuid())
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  type      ActivityType
  category  ActivityCategory
  source    ActivitySource
  outcome   CallOutcome?
  note      String?
  meta      Json? // štruktúrované detaily: napr. diff zmien { changes: [{ field, from, to }] } alebo verzia trackeru
  createdAt DateTime         @default(now())

  @@index([leadId])
  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([source, type, createdAt])
}

enum ActivityType {
  CALL
  QUOTE_SENT
  DESIGN_SENT
  EMAIL_SENT // info o nás, odpoveď, čokoľvek
  SMS_SENT
  NOTE
  NEXT_ACTION_SET
  NEXT_ACTION_CHANGED
  NEXT_ACTION_CLEARED
  CONTACT_UPDATED
  STATUS_CHANGED
  OWNER_CHANGED
  OUTCOME_CORRECTED
  TRACKER_ATTACHED // pripojený tracked link (dizajn/CP)
  TRACKER_UPDATED // nová verzia – „dizajn aktualizovaný"
  TRACKER_OPENED // klient otvoril (míľnik, hlavne po update)
}

enum CallOutcome {
  NO_ANSWER // 2b nezdvihli
  BAD_NUMBER // 2a zlé číslo
  NOT_INTERESTED // 2c nie
  CALL_AGAIN // 2d "zavolajte mi vtedy a vtedy"
  WANTS_QUOTE // 2e chce CP
  WANTS_DESIGN // 2f chce návrh
  WANTS_EMAIL // 2g máme napísať
  SNOOZE // 2h "o X mesiacov"
  POSITIVE // videli, páči sa, posúva sa to
}

enum Role {
  SCOUT // pridáva kontakty (vidí len svoje, kým nie sú obvolané)
  TELESALES // prvotné volanie / marketing – rieši calls
  MANAGER // vidí a rieši všetko
  ADMIN // všetko + používatelia, admin stránky
}

enum CallbackKind {
  RETRY // nedovolala sa – skúsiť znova, bez presného času
  SCHEDULED // dohodnutý čas – „pani povedala 15:00"
}

enum ActivityCategory {
  BUSINESS
  PLANNING
  AUDIT
}

enum ActivitySource {
  CALL_QUEUE
  PIPELINE
  CONTACTS
  ADMIN
}

enum NextActionKind {
  CALL
  SEND_QUOTE
  SEND_DESIGN
  SEND_EMAIL
  WAITING_FOR_CLIENT
  CUSTOM
}

enum LeadOrigin {
  MARKETING_CALL // klasický flow: marketing volá
  DIRECT // priamy kontakt (stretnutie, sám napísal)
  REFERRAL // odporúčanie
  OTHER
}

enum ProjectType {
  WEBSITE // obyčajná stránka
  ESHOP // eshop s platbou (Shopify)
  CATALOG // katalóg bez platby
  WEBAPP // webová aplikácia
  PORTFOLIO // portfólio
  OTHER // iné (vrátane „chce Zvonček")
}

// ── DIZAJN & TRACKING ────────────────────────────────────────────────────────
// Design = dizajnový návrh (patrí leadu): URL, repo, isLive, verzie, stav poslania.
// DesignVersion = log verzií (v1, v2…), každá môže mať vlastnú URL + poznámku.
// Tracker = sledovanie jedného návrhu (1:1): token + eventy. Token má @unique index,
//   takže ingest API ho nájde JEDNÝM indexovaným dotazom (include aj s návrhom a verziou).
// TrackerEvent = jednotlivé otvorenia/engagement, označkované verziou ktorú videli.

enum TrackedEventType {
  PAGE_VIEW // stránka sa načítala (slabý signál, môže byť skener)
  ENGAGED_VIEW // reálne pozretie (aktívny čas/scroll) – nesie durationMs
}

model Design {
  id             String    @id @default(cuid())
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId         String
  label          String? // "Variant A"
  targetUrl      String? // aktuálna URL návrhu (denormalizovaná z poslednej verzie)
  repoUrl        String? // GitHub repo – nech po vypnutí hostingu vieme, ktorý projekt to bol
  isLive         Boolean   @default(true) // ručný príznak: beží stránka? (pri vytvorení predpokladáme áno)
  currentVersion Int       @default(1)
  sentAt         DateTime? // kedy bol návrh označený ako poslaný klientovi (revertovateľné)
  createdById    String?
  deletedAt      DateTime? // soft delete

  versions  DesignVersion[]
  tracker   Tracker?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([leadId])
  @@index([deletedAt])
}

model DesignVersion {
  id          String   @id @default(cuid())
  design      Design   @relation(fields: [designId], references: [id], onDelete: Cascade)
  designId    String
  version     Int // 1, 2, 3…
  url         String? // URL platná pre túto verziu
  note        String? // „opravené čo chcel klient", „zmenené DNS"… alebo nič
  markedAt    DateTime @default(now())
  createdById String?

  events TrackerEvent[]

  @@unique([designId, version])
  @@index([designId])
}

model Tracker {
  id        String   @id @default(cuid())
  token     String   @unique // ingest API ho nájde jedným indexovaným dotazom
  design    Design   @relation(fields: [designId], references: [id], onDelete: Cascade)
  designId  String   @unique // 1:1 s návrhom
  createdAt DateTime @default(now())

  events TrackerEvent[]
}

model TrackerEvent {
  id        String  @id @default(cuid())
  tracker   Tracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  trackerId String

  version       DesignVersion? @relation(fields: [versionId], references: [id])
  versionId     String?
  versionAtView Int // ktorú verziu mal klient otvorenú v čase eventu

  type       TrackedEventType
  durationMs Int? // aktívny čas na stránke (ENGAGED_VIEW)
  ip         String? // surová IP – len pre hrubú geolokáciu (nie presná poloha)
  uaShort    String? // hrubý bucket user-agenta (bot heuristika)
  botFlag    Boolean          @default(false)
  occurredAt DateTime         @default(now())

  @@index([trackerId, occurredAt])
  @@index([type, occurredAt])
}
